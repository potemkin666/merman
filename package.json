{
  "name": "openclaw-harbor",
  "version": "1.0.0",
  "description": "OpenClaw Harbour - Desktop companion for OpenClaw",
  "main": "./out/main/index.js",
  "scripts": {
    "postinstall": "electron-rebuild || echo 'WARN: electron-rebuild failed — native modules like node-pty may not work. Run npm run rebuild manually.'",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron .",
    "pack": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:linux": "electron-vite build && electron-builder --linux",
    "rebuild": "electron-rebuild",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "com.openclaw.harbor",
    "productName": "OpenClaw Harbour",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "node_modules/node-pty/**/*",
      "!node_modules/node-pty/build/node_gyp_bins/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    }
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "optionalDependencies": {
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^41.2.1",
    "@electron/rebuild": "^4.0.3",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "^5.3.3",
    "vite": "^6.4.2",
    "vitest": "^4.1.4"
  }
}
